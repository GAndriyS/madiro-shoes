// Madiro domain model — see docs/requirements-analysis.md, section 3.
// The unit of stock is a concrete pair; variant = Style · Color (+ Material, Season set manually).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
}

enum Material {
  LEATHER
  SUEDE
}

// Internal name is "season"; UIs label it «Утеплення» (none / fleece / sheepskin).
enum Season {
  NONE
  BAIKA
  SHEEPSKIN
}

enum PairStatus {
  IN_STOCK
  SOLD
  WRITTEN_OFF
}

enum OperationType {
  INTAKE
  SALE
  RETURN
  WRITEOFF
}

enum PaymentMethod {
  CASH
  CARD
}

// A seller is "deleted" via deletedAt: the account disappears from the list
// and cannot log in, but their operations stay in the reports (FR-D-18).
model User {
  id           String    @id @default(cuid())
  name         String
  login        String    @unique
  passwordHash String
  role         Role      @default(SELLER)
  createdAt    DateTime  @default(now())
  /// Updated on every successful login; shown as seller activity in the dashboard.
  lastActiveAt DateTime?
  deletedAt    DateTime?

  pairsCreated Pair[]      @relation("PairCreatedBy")
  operations   Operation[]

  @@map("users")
}

// The purchase price is per variant (all sizes); it may be absent
// ("no price — old stock"). Historical prices are captured in Operation.
model Variant {
  id            String    @id @default(cuid())
  style         String
  color         String
  material      Material?
  season        Season?
  purchasePrice Decimal?  @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pairs Pair[]

  // Postgres treats NULLs as distinct, so uniqueness of combinations with
  // missing material/season is additionally enforced by the service layer.
  @@unique([style, color, material, season])
  @@index([style])
  @@map("variants")
}

// awaitingPrice — a seller's draft in the "awaiting price" queue: the pair is
// already in stock and sellable; the admin later sets a price or leaves none.
model Pair {
  id            String     @id @default(cuid())
  variantId     String
  variant       Variant    @relation(fields: [variantId], references: [id])
  size          Int
  status        PairStatus @default(IN_STOCK)
  awaitingPrice Boolean    @default(false)
  intakeDate    DateTime   @default(now())
  createdById   String?
  createdBy     User?      @relation("PairCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  operations Operation[]

  // Pair lookup on sale: match all 5 identity fields, take the oldest (FIFO).
  @@index([variantId, size, status])
  @@index([status, awaitingPrice])
  @@map("pairs")
}

// Movement history. purchasePriceAtTime is captured at operation time —
// later variant price changes do not rewrite history (section 3.3, item 1).
// Admin cancellation of an operation (section 7, item 2) — via cancelledAt.
model Operation {
  id                  String         @id @default(cuid())
  type                OperationType
  pairId              String
  pair                Pair           @relation(fields: [pairId], references: [id])
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  purchasePriceAtTime Decimal?       @db.Decimal(10, 2)
  salePrice           Decimal?       @db.Decimal(10, 2)
  paymentMethod       PaymentMethod?
  comment             String?
  cancelledAt         DateTime?
  createdAt           DateTime       @default(now())

  @@index([pairId])
  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("operations")
}
