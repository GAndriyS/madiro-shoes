# Скопіюйте у .env і заповніть значення. .env не комітиться.

# PostgreSQL (див. docker-compose.yml)
DATABASE_URL="postgresql://madiro:madiro@localhost:5432/madiro?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Початковий адміністратор (створюється сідом: pnpm --filter @madiro/api db:seed)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD=""
ADMIN_NAME="Адміністратор"

# Vision-провайдер (фаза 1: Gemini Flash)
GEMINI_API_KEY=""
