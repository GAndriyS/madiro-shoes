# Copy to .env and fill in the values. .env is not committed.

# PostgreSQL (see docker-compose.yml)
DATABASE_URL="postgresql://madiro:madiro@localhost:5432/madiro?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Initial administrator (created by the seed: pnpm --filter @madiro/api db:seed)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD=""
ADMIN_NAME="Адміністратор"

# Vision provider (phase 1: Gemini Flash)
GEMINI_API_KEY=""
