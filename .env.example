# Copy to .env and fill in the values. .env is not committed.

# PostgreSQL (see docker-compose.yml)
DATABASE_URL="postgresql://madiro:madiro@localhost:5432/madiro?schema=public"

# JWT — each secret must be >= 32 chars; generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-openssl-rand-hex-32-value"
JWT_REFRESH_SECRET="replace-with-openssl-rand-hex-32-value"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# CORS: comma-separated browser origins allowed to call the API
# (dashboard dev is 5173; add the scanner origin when it lands)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Initial administrator (created by the seed: pnpm --filter @madiro/api db:seed)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD=""
ADMIN_NAME="Адміністратор"

# Vision provider (phase 1: Gemini Flash)
GEMINI_API_KEY=""
